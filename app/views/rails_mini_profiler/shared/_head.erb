<head>
  <title>Rails Mini Profiler</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-cache-control" content="no-cache">

  <%= javascript_importmap_tags "application", importmap: RailsMiniProfiler.importmap %>
  <%#
    Link each stylesheet through Rails' asset helpers instead of chaining them
    with CSS @import in rails-mini-profiler.css. sprockets and propshaft rewrite
    @import url() paths incompatibly (no single relative path resolves on both),
    so we let asset_path build each digested URL, which works on either pipeline.

    Order matters: this reproduces the original @import cascade exactly. The
    component parts load first and rails-mini-profiler.css loads last, so its
    utility rules (e.g. `.hidden { display: none }`) win over same-specificity
    component rules (e.g. `.dropdown-container { display: flex }`) — otherwise
    every `.dropdown-container.hidden` menu would render open by default.
  %>
  <% %w[
    rails_mini_profiler/flashes
    rails_mini_profiler/flamegraph
    rails_mini_profiler/components/profiled_request_table
    rails_mini_profiler/profiled_requests
    rails_mini_profiler/traces
    rails_mini_profiler/components/buttons
    rails_mini_profiler/components/input
    rails_mini_profiler/components/navbar
    rails_mini_profiler/components/pagination
    rails_mini_profiler/components/page_header
    rails_mini_profiler/components/dropdown
    rails_mini_profiler/components/placeholder
    rails_mini_profiler/components/trace
    rails_mini_profiler/components/tooltip
    rails_mini_profiler/rails-mini-profiler
  ].each do |stylesheet| %>
    <%= stylesheet_link_tag stylesheet, "data-turbo-track": "reload" %>
  <% end %>
</head>
